{
  "name": "our-pins",
  "version": "0.1.0",
  "private": true,
  "description": "A private, community-curated map of Japan for trusted diaspora groups. v1: Greeks in Japan.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff",
    "db:types": "supabase gen types typescript --local > src/lib/supabase/database.types.ts"
  },
  "dependencies": {
    "@googlemaps/markerclusterer": "2.5.3",
    "@googlemaps/js-api-loader": "1.16.8",
    "@hookform/resolvers": "3.9.1",
    "@supabase/ssr": "0.5.2",
    "@supabase/supabase-js": "2.46.1",
    "@tanstack/react-query": "5.62.0",
    "browser-image-compression": "2.0.2",
    "clsx": "2.1.1",
    "jose": "5.9.6",
    "lucide-react": "0.468.0",
    "next": "15.1.0",
    "next-intl": "3.26.0",
    "next-themes": "0.4.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "7.54.0",
    "tailwind-merge": "2.5.5",
    "vaul": "1.1.2",
    "zod": "3.23.8",
    "zustand": "5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "1.49.0",
    "@tailwindcss/postcss": "4.0.0-beta.6",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/google.maps": "3.58.1",
    "@types/node": "22.10.1",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "@vitejs/plugin-react": "4.3.4",
    "eslint": "9.16.0",
    "eslint-config-next": "15.1.0",
    "jsdom": "25.0.1",
    "postcss": "8.4.49",
    "prettier": "3.4.1",
    "prettier-plugin-tailwindcss": "0.6.9",
    "supabase": "1.219.2",
    "tailwindcss": "4.0.0-beta.6",
    "typescript": "5.7.2",
